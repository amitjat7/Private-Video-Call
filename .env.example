env
# ═══════════════════════════════════════════════════
# Private Video Call - Environment Configuration
# Copy this file to .env and fill in your own values
# ═══════════════════════════════════════════════════

# Server port
PORT=3000

# Ngrok tunnel auth token (get from https://dashboard.ngrok.com)
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# Telegram bot notifications (get token from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# GitHub profile link (shown in website footer)
GITHUB_URL=https://github.com/yourhandle

# TURN server for reliable video relay (OPTIONAL but recommended)
# Get free credentials at https://www.metered.ca (50GB/month free)
# Leave empty to use public fallback relays
TURN_URL=turn:global.relay.metered.ca:80,turn:global.relay.metered.ca:80?transport=tcp,turn:global.relay.metered.ca:443,turns:global.relay.metered.ca:443?transport=tcp
TURN_USERNAME=your_turn_username_here
TURN_CREDENTIAL=your_turn_credential_here
